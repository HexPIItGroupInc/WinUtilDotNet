{
  "WPFTweaksHiber": {
    "apply": [{ "file": "powercfg.exe", "args": "/hibernate off" }],
    "undo": [{ "file": "powercfg.exe", "args": "/hibernate on" }]
  },
  "WPFTweaksTeredo": {
    "apply": [{ "file": "netsh.exe", "args": "interface teredo set state disabled" }],
    "undo": [{ "file": "netsh.exe", "args": "interface teredo set state default" }]
  },
  "WPFTweaksReservedStorage": {
    "apply": [{ "file": "dism.exe", "args": "/Online /Set-ReservedStorageState /State:Disabled" }],
    "undo": [{ "file": "dism.exe", "args": "/Online /Set-ReservedStorageState /State:Enabled" }]
  },
  "WPFTweaksDisableStoreSearch": {
    "apply": [{ "file": "icacls.exe", "args": "\"%LocalAppData%\\Packages\\Microsoft.WindowsStore_8wekyb3d8bbwe\\LocalState\\store.db\" /deny Everyone:F" }],
    "undo": [{ "file": "icacls.exe", "args": "\"%LocalAppData%\\Packages\\Microsoft.WindowsStore_8wekyb3d8bbwe\\LocalState\\store.db\" /grant Everyone:F" }]
  },
  "WPFTweaksWidget": {
    "preApply": [
      { "file": "taskkill.exe", "args": "/f /im Widgets.exe", "ignoreExitCode": true },
      { "file": "taskkill.exe", "args": "/f /im WidgetService.exe", "ignoreExitCode": true }
    ],
    "appxRemove": ["Microsoft.WidgetsPlatformRuntime", "MicrosoftWindows.Client.WebExperience"],
    "apply": [
      { "file": "taskkill.exe", "args": "/f /im explorer.exe", "ignoreExitCode": true },
      { "file": "explorer.exe", "args": "", "ignoreExitCode": true }
    ],
    "undo": []
  },
  "WPFTweaksDisplay": {
    "registry": [
      {
        "Path": "HKCU:\\Control Panel\\Desktop",
        "Name": "UserPreferencesMask",
        "Value": "9012038010000000",
        "Type": "Binary"
      }
    ],
    "undo": []
  },
  "WPFTweaksDisableIPv6": {
    "registry": [
      {
        "Path": "HKLM:\\SYSTEM\\CurrentControlSet\\Services\\Tcpip6\\Parameters",
        "Name": "DisabledComponents",
        "Value": "255",
        "Type": "DWord"
      }
    ],
    "undo": []
  },
  "WPFTweaksServices": {
    "registry": [
      {
        "Path": "HKLM:\\SYSTEM\\CurrentControlSet\\Control",
        "Name": "SvcHostSplitThresholdInKB",
        "Value": "{{RAM_KB}}",
        "Type": "DWord"
      }
    ],
    "undo": []
  },
  "WPFTweaksRightClickMenu": {
    "registry": [
      {
        "Path": "HKCU:\\Software\\Classes\\CLSID\\{86ca1aa0-34aa-4e8b-a509-50c905bae2a2}\\InprocServer32",
        "Name": "",
        "Value": "",
        "Type": "String"
      }
    ],
    "apply": [
      { "file": "taskkill.exe", "args": "/f /im explorer.exe", "ignoreExitCode": true },
      { "file": "explorer.exe", "args": "", "ignoreExitCode": true }
    ],
    "undoRegistryDeleteKeys": ["HKCU:\\Software\\Classes\\CLSID\\{86ca1aa0-34aa-4e8b-a509-50c905bae2a2}"],
    "undo": [
      { "file": "taskkill.exe", "args": "/f /im explorer.exe", "ignoreExitCode": true },
      { "file": "explorer.exe", "args": "", "ignoreExitCode": true }
    ]
  },
  "WPFToggleDarkMode": {
    "apply": [
      { "file": "taskkill.exe", "args": "/f /im explorer.exe", "ignoreExitCode": true },
      { "file": "explorer.exe", "args": "", "ignoreExitCode": true }
    ],
    "undo": [
      { "file": "taskkill.exe", "args": "/f /im explorer.exe", "ignoreExitCode": true },
      { "file": "explorer.exe", "args": "", "ignoreExitCode": true }
    ]
  },
  "WPFTweaksDisableExplorerAutoDiscovery": {
    "registryDeleteKeys": [
      "HKCU:\\Software\\Classes\\Local Settings\\Software\\Microsoft\\Windows\\Shell\\Bags",
      "HKCU:\\Software\\Classes\\Local Settings\\Software\\Microsoft\\Windows\\Shell\\BagMRU"
    ],
    "registry": [
      {
        "Path": "HKCU:\\Software\\Classes\\Local Settings\\Software\\Microsoft\\Windows\\Shell\\Bags\\AllFolders\\Shell",
        "Name": "FolderType",
        "Value": "NotSpecified",
        "Type": "String"
      }
    ],
    "undoRegistryDeleteKeys": [
      "HKCU:\\Software\\Classes\\Local Settings\\Software\\Microsoft\\Windows\\Shell\\Bags",
      "HKCU:\\Software\\Classes\\Local Settings\\Software\\Microsoft\\Windows\\Shell\\BagMRU"
    ],
    "undo": []
  },
  "WPFTweaksDeleteTempFiles": {
    "deletePaths": ["%Temp%\\*", "%SystemRoot%\\Temp\\*"],
    "undo": []
  },
  "WPFTweaksBlockAdobeNet": {
    "hostsBlock": {
      "url": "https://github.com/Ruddernation-Designs/Adobe-URL-Block-List/raw/refs/heads/master/hosts",
      "removeFromMarker": "#New Ver"
    },
    "apply": [{ "file": "ipconfig.exe", "args": "/flushdns" }],
    "undo": [{ "file": "ipconfig.exe", "args": "/flushdns" }]
  },
  "WPFTweaksRazerBlock": {
    "ensureDirs": ["%SystemRoot%\\Installer\\Razer"],
    "deletePaths": ["%SystemRoot%\\Installer\\Razer\\*"],
    "apply": [{ "file": "icacls.exe", "args": "\"%SystemRoot%\\Installer\\Razer\" /deny Everyone:(W)" }],
    "undo": [{ "file": "icacls.exe", "args": "\"%SystemRoot%\\Installer\\Razer\" /remove:d Everyone" }]
  },
  "WPFTweaksDiskCleanup": {
    "apply": [
      { "file": "cleanmgr.exe", "args": "/d C: /VERYLOWDISK", "ignoreExitCode": true },
      { "file": "dism.exe", "args": "/online /Cleanup-Image /StartComponentCleanup /ResetBase" }
    ],
    "undo": []
  },
  "WPFToggleShowExt": {
    "apply": [
      { "file": "taskkill.exe", "args": "/f /im explorer.exe", "ignoreExitCode": true },
      { "file": "explorer.exe", "args": "", "ignoreExitCode": true }
    ],
    "undo": [
      { "file": "taskkill.exe", "args": "/f /im explorer.exe", "ignoreExitCode": true },
      { "file": "explorer.exe", "args": "", "ignoreExitCode": true }
    ]
  },
  "WPFToggleHiddenFiles": {
    "apply": [
      { "file": "taskkill.exe", "args": "/f /im explorer.exe", "ignoreExitCode": true },
      { "file": "explorer.exe", "args": "", "ignoreExitCode": true }
    ],
    "undo": [
      { "file": "taskkill.exe", "args": "/f /im explorer.exe", "ignoreExitCode": true },
      { "file": "explorer.exe", "args": "", "ignoreExitCode": true }
    ]
  },
  "WPFToggleStartMenuRecommendations": {
    "apply": [
      { "file": "taskkill.exe", "args": "/f /im explorer.exe", "ignoreExitCode": true },
      { "file": "explorer.exe", "args": "", "ignoreExitCode": true }
    ],
    "undo": [
      { "file": "taskkill.exe", "args": "/f /im explorer.exe", "ignoreExitCode": true },
      { "file": "explorer.exe", "args": "", "ignoreExitCode": true }
    ]
  },
  "WPFToggleTaskbarAlignment": {
    "apply": [
      { "file": "taskkill.exe", "args": "/f /im explorer.exe", "ignoreExitCode": true },
      { "file": "explorer.exe", "args": "", "ignoreExitCode": true }
    ],
    "undo": [
      { "file": "taskkill.exe", "args": "/f /im explorer.exe", "ignoreExitCode": true },
      { "file": "explorer.exe", "args": "", "ignoreExitCode": true }
    ]
  }
}
