{
  "WPFTweaksHiber": {
    "apply": [
      {
        "file": "powercfg.exe",
        "args": "/hibernate off"
      }
    ],
    "undo": [
      {
        "file": "powercfg.exe",
        "args": "/hibernate on"
      }
    ]
  },
  "WPFTweaksTeredo": {
    "apply": [
      {
        "file": "netsh.exe",
        "args": "interface teredo set state disabled"
      }
    ],
    "undo": [
      {
        "file": "netsh.exe",
        "args": "interface teredo set state default"
      }
    ]
  },
  "WPFTweaksReservedStorage": {
    "apply": [
      {
        "file": "dism.exe",
        "args": "/Online /Set-ReservedStorageState /State:Disabled"
      }
    ],
    "undo": [
      {
        "file": "dism.exe",
        "args": "/Online /Set-ReservedStorageState /State:Enabled"
      }
    ]
  },
  "WPFTweaksDisableStoreSearch": {
    "apply": [
      {
        "file": "icacls.exe",
        "args": "\"%LocalAppData%\\Packages\\Microsoft.WindowsStore_8wekyb3d8bbwe\\LocalState\\store.db\" /deny Everyone:F",
        "ignoreExitCode": true
      }
    ],
    "undo": [
      {
        "file": "icacls.exe",
        "args": "\"%LocalAppData%\\Packages\\Microsoft.WindowsStore_8wekyb3d8bbwe\\LocalState\\store.db\" /grant Everyone:F",
        "ignoreExitCode": true
      }
    ]
