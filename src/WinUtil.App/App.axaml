<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="WinUtil.App.App"
             RequestedThemeVariant="Dark">
  <Application.Styles>
    <FluentTheme />

    <Style Selector="Window">
      <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif" />
      <Setter Property="Background" Value="#0E1116" />
    </Style>

    <Style Selector="Border.card">
      <Setter Property="Background" Value="#161B22" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="16,12" />
      <Setter Property="Margin" Value="0,0,0,8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="#1F2630" />
    </Style>
    <Style Selector="Border.card:pointerover">
      <Setter Property="BorderBrush" Value="#31405A" />
    </Style>

    <Style Selector="Border.chip">
      <Setter Property="CornerRadius" Value="99" />
      <Setter Property="Padding" Value="10,3" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.chip > TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.action">
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="Padding" Value="14,6" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#2563EB" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#3B82F6" />
    </Style>

    <Style Selector="ListBox.nav ListBoxItem">
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="Margin" Value="0,1" />
    </Style>
  </Application.Styles>
</Application>
