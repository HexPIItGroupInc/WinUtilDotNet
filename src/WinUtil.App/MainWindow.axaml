<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WinUtil.App.ViewModels"
        x:Class="WinUtil.App.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="WinUtil — native .NET"
        Width="1180" Height="760" MinWidth="900"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

  <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="235,*">

    <!-- Header -->
    <Border Grid.Row="0" Grid.ColumnSpan="2" Padding="20,14" Background="#11151C">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Text="WinUtil" FontSize="20" FontWeight="Bold" />
          <TextBlock Text=".NET" FontSize="20" FontWeight="Bold" Foreground="#3B82F6" />
        </StackPanel>

        <Border Grid.Column="1" Classes="chip" Background="#132A4A" Margin="16,0,0,0">
          <TextBlock Text="{Binding CoverageText}" Foreground="#7EB3FF" />
        </Border>

        <TextBlock Grid.Column="2" Text="{Binding SummaryText}" Margin="16,0,0,0"
                   VerticalAlignment="Center" Foreground="#8B96A3" FontSize="12" FontWeight="SemiBold" />

        <TextBox Grid.Column="3" Width="260" Watermark="Search tweaks…"
                 Text="{Binding Search, Mode=TwoWay}" CornerRadius="8" VerticalAlignment="Center" />

        <Button Grid.Column="4" Classes="action" Margin="10,0,0,0" VerticalAlignment="Center"
                Command="{Binding RefreshDetectionCommand}" IsEnabled="{Binding EngineAvailable}"
                Content="Re-detect" />
      </Grid>
    </Border>

    <!-- Sidebar -->
    <Border Grid.Row="1" Grid.Column="0" Padding="12" Background="#11151C">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="CATEGORIES" FontSize="11" FontWeight="SemiBold"
                   Foreground="#5B6672" Margin="12,4,0,8" />
        <ListBox Classes="nav" Background="Transparent"
                 ItemsSource="{Binding Categories}"
                 SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="x:String">
              <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding}" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <!-- Tweak list. Extra right padding keeps the floating scrollbar from
         overlapping the action buttons. -->
    <ScrollViewer Grid.Row="1" Grid.Column="1" Padding="20,16,34,16"
                  HorizontalScrollBarVisibility="Disabled">
      <ItemsControl ItemsSource="{Binding FilteredTweaks}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:TweakItemViewModel">
            <Border Classes="card">
              <!-- Fixed action rail: chips and buttons align across all cards,
                   descriptions can never crowd or clip them. Left accent bar
                   marks applied (green) / drifted (amber) at a glance. -->
              <Grid ColumnDefinitions="4,*,290">
                <Border Grid.Column="0" Background="{Binding AccentBrush}"
                        CornerRadius="2" Margin="-8,-4,10,-4" />
                <StackPanel Grid.Column="1" Spacing="3" Margin="0,0,16,0">
                  <!-- Title in a bounded * column so long titles wrap instead of
                       forcing the card wider than the window. -->
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding Name}" TextWrapping="Wrap"
                               FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
                    <Border Grid.Column="1" Classes="chip" Background="#3A2A10"
                            Margin="8,0,0,0" VerticalAlignment="Center"
                            IsVisible="{Binding IsScript}">
                      <TextBlock Text="script" Foreground="#F0B35C" />
                    </Border>
                  </Grid>
                  <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                             Foreground="#8B96A3" FontSize="12" />
                  <!-- Actionable explanation after a failed apply/undo. -->
                  <Border Background="#3A2A10" CornerRadius="6" Padding="10,6" Margin="0,4,0,0"
                          IsVisible="{Binding HasMessage}">
                    <TextBlock Text="{Binding ActionMessage}" TextWrapping="Wrap"
                               Foreground="#F0B35C" FontSize="12" />
                  </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center" HorizontalAlignment="Right">
                  <Border Classes="chip" Background="{Binding ChipBackground}">
                    <TextBlock Text="{Binding StateText}" Foreground="{Binding StateBrush}" />
                  </Border>
                  <Button Classes="action primary" Content="{Binding ApplyLabel}"
                          Command="{Binding ApplyCommand}" IsVisible="{Binding ShowApply}" />
                  <Button Classes="action" Content="Undo"
                          Command="{Binding UndoCommand}" IsVisible="{Binding ShowUndo}" /><!-- ApplyCommand/UndoCommand generated from ApplyAsync/UndoAsync -->
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Status bar -->
    <Border Grid.Row="2" Grid.ColumnSpan="2" Padding="20,8" Background="#11151C">
      <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#5B6672" />
    </Border>
  </Grid>
</Window>
