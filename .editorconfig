root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{json,yml,yaml,csproj,props,targets,sln}]
indent_size = 2

[*.cs]
# File-scoped namespaces, var preferences, expression-bodied members where clear
csharp_style_namespace_declarations = file_scoped:error
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion
csharp_prefer_braces = true:warning
dotnet_style_qualification_for_field = false:warning
dotnet_sort_system_directives_first = true

# Naming: interfaces start with I
dotnet_naming_rule.interfaces_begin_with_i.severity = error
dotnet_naming_rule.interfaces_begin_with_i.symbols = interface_symbols
dotnet_naming_rule.interfaces_begin_with_i.style = prefix_i
dotnet_naming_symbols.interface_symbols.applicable_kinds = interface
dotnet_naming_style.prefix_i.required_prefix = I
dotnet_naming_style.prefix_i.capitalization = pascal_case
